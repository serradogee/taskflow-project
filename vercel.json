{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "api/client.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/post/api/v1/tasks(.*)",
      "dest": "server/src/index.js"
    },
    {
      "src": "/api/v1/tasks(.*)",
      "dest": "server/src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
