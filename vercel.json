{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/post/api/v1/tasks(.*)", "dest": "server/src/index.js" },
    { "src": "/api/v1/tasks(.*)", "dest": "server/src/index.js" },
    { "src": "/(.*)", "dest": "server/src/index.js" }
  ]
}
