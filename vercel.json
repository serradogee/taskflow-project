{
  "version": 2,
  "rewrites": [
    {
      "source": "/post/api/(.*)",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/server/src/index.js"
    }
  ],
  "functions": {
    "server/src/index.js": {
      "runtime": "@vercel/node"
    }
  }
}
